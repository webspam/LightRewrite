<?xml version="1.0" encoding="UTF-16"?>
<UserConfig>
    <Group id="LightRewrite_General" displayName="Mods.LightRewrite">
        <VisibleVars>
            <Var id="Enabled" displayName="LightRewrite_Enabled" displayType="TOGGLE" />
            <Var id="CurrentProfile" displayName="LightRewrite_CurrentProfile" displayType="OPTIONS">
              <OptionsArray>
                <Option id="0" displayName="LightRewrite_Preset_Author">
                  <Entry varId="CurrentProfile" value="0" />
                </Option>
                <!-- Placeholders; required for variable slider list. -->
                <Option id="1"><Entry varId="CurrentProfile" value="1" /></Option>
                <Option id="2"><Entry varId="CurrentProfile" value="2" /></Option>
                <Option id="3"><Entry varId="CurrentProfile" value="3" /></Option>
                <Option id="4"><Entry varId="CurrentProfile" value="4" /></Option>
                <Option id="5"><Entry varId="CurrentProfile" value="5" /></Option>
                <Option id="6"><Entry varId="CurrentProfile" value="6" /></Option>
                <Option id="7"><Entry varId="CurrentProfile" value="7" /></Option>
                <Option id="8"><Entry varId="CurrentProfile" value="8" /></Option>
                <Option id="9"><Entry varId="CurrentProfile" value="9" /></Option>
              </OptionsArray>
            </Var>
            <Var id="SpacingMode" displayName="LightRewrite_Spacing_Mode" displayType="OPTIONS">
              <OptionsArray>
                <Option id="0" displayName="LightRewrite_None">
                  <Entry varId="SpacingMode" value="0" />
                </Option>
                <Option id="1" displayName="LightRewrite_Spacing_Mode_Centres">
                  <Entry varId="SpacingMode" value="1" />
                </Option>
                <Option id="2" displayName="LightRewrite_Spacing_Mode_Count">
                  <Entry varId="SpacingMode" value="2" />
                </Option>
                <Option id="3" displayName="LightRewrite_Spacing_Mode_Volume">
                  <Entry varId="SpacingMode" value="3" />
                </Option>
              </OptionsArray>
            </Var>
            <Var id="SpacingCount" displayName="LightRewrite_Spacing_Count"
                displayType="SLIDER;0;10;10" tags="indent" />
            <Var id="SpacingBudget" displayName="LightRewrite_Spacing_Budget"
                displayType="SLIDER;0.5;10;19" tags="indent" />

            <!-- Internal: Tracks the version of the config that was last initialised. -->
            <Var id="InitVersion" displayName="LightRewrite_InitVersion"
                displayType="SLIDER;0;9;9" visibilityCondition="hideAlways" />
        </VisibleVars>
    </Group>
</UserConfig>